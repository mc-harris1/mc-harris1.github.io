---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  repo?: string;
  live?: string;
}

const { title, description, tags = [], repo, live } = Astro.props;
---

<article class="border border-border rounded-lg p-6 hover:border-foreground-muted transition-colors">
  <h2 class="text-xl font-semibold mb-2">{title}</h2>
  <p class="text-foreground-muted mb-4">{description}</p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-1 rounded bg-surface-alt text-foreground-muted">
          {tag}
        </span>
      ))}
    </div>
  )}

  <div class="flex gap-4 text-sm">
    {repo && (
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-hover transition-colors glitch-hover"
      >
        Repository
      </a>
    )}
    {live && (
      <a
        href={live}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-hover transition-colors glitch-hover"
      >
        Live Demo
      </a>
    )}
  </div>
</article>

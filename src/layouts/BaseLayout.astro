---
import "../styles/global.css";
import FooterSocialLinks from "../components/FooterSocialLinks.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Engineering portfolio and consulting platform" } = Astro.props;

const socialLinks = [
  { url: "https://github.com/mc-harris1", icon: "github" as const, label: "GitHub" },
  { url: "https://www.linkedin.com/in/mc-harris", icon: "linkedin" as const, label: "LinkedIn" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-534XM6GS');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | mc-harris.dev</title>
  </head>
  <body class="bg-surface text-foreground min-h-screen flex flex-col antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-534XM6GS"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="border-b border-border">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight hover:text-accent transition-colors">
          mc-harris
        </a>
        <ul class="flex gap-6 text-sm">
          <li><a href="/" class="text-foreground-muted hover:text-foreground transition-colors glitch-hover">Home</a></li>
          <li><a href="/about" class="text-foreground-muted hover:text-foreground transition-colors glitch-hover">About</a></li>
          <li><a href="/projects" class="text-foreground-muted hover:text-foreground transition-colors glitch-hover">Projects</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto px-6 py-12 w-full">
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between text-sm text-foreground-muted">
        <span>&copy; {new Date().getFullYear()} mc-harris</span>
        <FooterSocialLinks links={socialLinks} />
      </div>
    </footer>
  </body>
</html>

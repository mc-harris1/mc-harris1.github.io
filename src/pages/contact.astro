---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Get in touch for consulting or collaboration.">
  <section class="py-12 max-w-3xl">
    <h1 class="text-3xl font-bold tracking-tight mb-6">Contact</h1>

    <div class="space-y-6 text-foreground-muted leading-relaxed">
      <p>
        Interested in working together or have a question? Reach out directly.
      </p>

      <div class="flex flex-col gap-4 mt-4">
        <a
          href="mailto:contact@mc-harris.dev"
          class="inline-flex items-center gap-2 text-accent hover:text-accent-hover transition-colors"
        >
          <span>contact@mc-harris.dev</span>
        </a>
        <a
          href="https://github.com/mc-harris1"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-accent hover:text-accent-hover transition-colors"
        >
          <span>github.com/mc-harris1</span>
        </a>
        <a
          href="https://www.linkedin.com/in/mc-harris"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-accent hover:text-accent-hover transition-colors"
        >
          <span>linkedin.com/in/mc-harris</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
